{
  "name": "toody-v2",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "playwright test",
    "test:report": "playwright test --reporter=html",
    "test:buttons": "playwright test tests/buttons.spec.js --reporter=line",
    "test:flow": "node --input-type=module --eval \"import('./api/test-session-flow.js').then(({testSessionFlow})=>testSessionFlow()).then(r=>{console.log(JSON.stringify(r,null,2));process.exit(r.overallPass?0:1);})\"",
    "test:regression": "node api/regression-agent.js",
    "predeploy": "npm run test:buttons && npm run test:flow && npm run test:regression",
    "deploy": "git add . && git commit -m \"deploy: latest fixes\" && git push && firebase deploy --only hosting"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/atuldctoody/toody-v2.git"
  },
